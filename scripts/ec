# Modified by: Dan Harms
# Keywords: emacs tools

srv=${ESRV:-$(hostname -s)}
"$EMACS_CLIENT" -q -s "$srv" -n -r "$@"
if [ "$(uname)" = "Darwin" ] && [ "$(command -v _darwin_fg.sh)" ]; then
    _darwin_fg.sh
fi

# code ends here
